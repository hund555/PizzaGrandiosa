<Window x:Class="PizzaWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Pizza Grandiosa — Orders" Height="480" Width="640"
        WindowStartupLocation="CenterScreen">
  <Grid Margin="10">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <TextBlock Text="Incoming Orders" FontSize="18" FontWeight="Bold" />

    <ListView Grid.Row="1" ItemsSource="{Binding Orders}" Margin="0,10,0,10">
      <ListView.ItemTemplate>
        <DataTemplate>
          <Border Padding="8" Margin="4" BorderBrush="Gray" BorderThickness="1" CornerRadius="4">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="180"/>
                <ColumnDefinition Width="160"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>

              <TextBlock Grid.Column="0" Text="{Binding OrderId}" FontWeight="SemiBold" VerticalAlignment="Center" />
              <TextBlock Grid.Column="1" Text="{Binding StatusMessage}" VerticalAlignment="Center" />

              <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Accept" Margin="6,0" Command="{Binding DataContext.AcceptCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" />
                <Button Content="Decline" Margin="6,0" Command="{Binding DataContext.DeclineCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" />
              </StackPanel>
            </Grid>
          </Border>
        </DataTemplate>
      </ListView.ItemTemplate>
    </ListView>

    <TextBlock Grid.Row="2" Text="{Binding StatusBar}" FontStyle="Italic" Foreground="DarkSlateGray" />
  </Grid>
</Window>